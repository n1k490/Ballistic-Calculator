<Window x:Class="PrecisionBallistics.App.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PrecisionBallistics.App"
        Title="Trajectory chart — ტრაექტორიის გრაფიკი"
        Height="520" Width="820"
        WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource Card}" Margin="8">
        <local:TrajectoryChart x:Name="Chart"/>
    </Border>
</Window>
