<Window x:Class="PrecisionBallistics.App.TruingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MV truing — სიჩქარის დათვლა ვარდნით"
        Height="560" Width="470"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Style="{StaticResource Card}" Margin="8">
        <StackPanel>
            <TextBlock Text="MUZZLE VELOCITY — TRUING BY DROP" Style="{StaticResource SectionHeader}"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"
                       Text="გასწორებული ხარ ერთ მანძილზე (zero), ისროლე ერთ ან რამდენიმე მანძილზე და გაზომე ჯგუფის ვარდნა დამიზნების წერტილიდან. ერთი წერტილით — პირდაპირი ამოხსნა; რამდენიმეთი — best-fit. დანარჩენი (BC, ატმოსფერო, sight height) მიმდინარე პროფილიდან."/>

            <TextBlock x:Name="InfoText" TextWrapping="Wrap" Foreground="{StaticResource AccentBrush}"
                       FontSize="11" Margin="0,0,0,10"/>

            <TextBlock x:Name="ZeroLabel" Style="{StaticResource FieldLabel}"/>
            <TextBox x:Name="ZeroBox"/>

            <TextBlock x:Name="ObsLabel" Style="{StaticResource FieldLabel}" Margin="0,8,0,0"/>
            <TextBox x:Name="ObsBox" AcceptsReturn="True" Height="110"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas"/>
            <TextBlock x:Name="ObsHint" Foreground="{StaticResource MutedBrush}" FontSize="11" Margin="0,2,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <Button Content="Calculate" Click="OnCalc" Style="{StaticResource AccentButton}" Width="110"/>
                <Button Content="Apply to load" Click="OnApply" Width="120" Margin="8,0,0,0"/>
                <Button Content="Close" Click="OnClose" Width="80" Margin="8,0,0,0"/>
            </StackPanel>

            <Border Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="4" Margin="0,14,0,0" Padding="12">
                <StackPanel>
                    <TextBlock Text="RESULT" Foreground="{StaticResource MutedBrush}" FontSize="10"/>
                    <TextBlock x:Name="ResultText" Text="—" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock x:Name="ResultNote" Text="" Foreground="{StaticResource MutedBrush}"
                               FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
