<Window x:Class="PrecisionBallistics.App.DragCurveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Custom drag curve — CDM"
        Height="600" Width="480"
        WindowStartupLocation="CenterOwner">
    <Border Style="{StaticResource Card}" Margin="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CUSTOM DRAG CURVE (Mach, Cd)" Style="{StaticResource SectionHeader}"/>
            <TextBlock Grid.Row="1" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"
                       Text="ჩასვი ან ჩატვირთე Mach,Cd ცხრილი (თითო წერტილი ხაზზე, მაგ Lapua-ს Doppler მონაცემები). ≥2 წერტილი. გამოყენებისას drag model გადადის Custom-ზე."/>

            <TextBox Grid.Row="2" x:Name="CsvBox" AcceptsReturn="True" AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" TextWrapping="NoWrap"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10">
                <Button Content="Import file…" Click="OnImport" Width="120"/>
                <Button Content="Apply to load" Click="OnApply" Style="{StaticResource AccentButton}" Width="130" Margin="8,0,0,0"/>
                <Button Content="Clear (use G7)" Click="OnClear" Width="120" Margin="8,0,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="4" x:Name="StatusText" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
        </Grid>
    </Border>
</Window>
